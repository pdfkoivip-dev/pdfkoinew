{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.pdfkoi.com"
        }
      ],
      "destination": "https://pdfkoi.com/:path*",
      "permanent": true
    },
    {
      "source": "/tools",
      "has": [
        {
          "type": "query",
          "key": "category",
          "value": "(?<legacyCategory>edit-annotate|convert-to-pdf|convert-from-pdf|organize-manage|optimize-repair|secure-pdf)"
        }
      ],
      "destination": "/tools/category/:legacyCategory",
      "permanent": true
    },
    {
      "source": "/:locale/tools",
      "has": [
        {
          "type": "query",
          "key": "category",
          "value": "(?<legacyCategory>edit-annotate|convert-to-pdf|convert-from-pdf|organize-manage|optimize-repair|secure-pdf)"
        }
      ],
      "destination": "/:locale/tools/category/:legacyCategory",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "ref",
          "value": "producthunt"
        }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tools",
      "has": [
        {
          "type": "query",
          "key": "q",
          "value": "\\{search_term_string\\}"
        }
      ],
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/:locale/tools",
      "has": [
        {
          "type": "query",
          "key": "q",
          "value": "\\{search_term_string\\}"
        }
      ],
      "destination": "/:locale/tools",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/zh-TW",
      "destination": "/zh-tw",
      "permanent": true
    },
    {
      "source": "/zh-TW/",
      "destination": "/zh-tw/",
      "permanent": true
    },
    {
      "source": "/zh-TW/:path*",
      "destination": "/zh-tw/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/tools/:path*",
      "destination": "/en/tools/:path*"
    },
    {
      "source": "/workflow/:path*",
      "destination": "/en/workflow/:path*"
    },
    {
      "source": "/about/:path*",
      "destination": "/en/about/:path*"
    },
    {
      "source": "/faq/:path*",
      "destination": "/en/faq/:path*"
    },
    {
      "source": "/privacy/:path*",
      "destination": "/en/privacy/:path*"
    },
    {
      "source": "/cookies/:path*",
      "destination": "/en/cookies/:path*"
    },
    {
      "source": "/contact/:path*",
      "destination": "/en/contact/:path*"
    },
    {
      "source": "/terms/:path*",
      "destination": "/en/terms/:path*"
    },
    {
      "source": "/compress-pdf-for-email/:path*",
      "destination": "/en/compress-pdf-for-email/:path*"
    },
    {
      "source": "/compress-pdf-without-upload/:path*",
      "destination": "/en/compress-pdf-without-upload/:path*"
    },
    {
      "source": "/merge-pdf-no-signup/:path*",
      "destination": "/en/merge-pdf-no-signup/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|avif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(wasm)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    },
    {
      "source": "/workers/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pdfjs-viewer/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.mjs",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
